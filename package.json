{
  "name": "english-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:uno": "tsc -b && vite build --outDir ../uno/AppUno/WebContent --emptyOutDir",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "curate:archive": "node scripts/curate-archive-lessons.mjs",
    "proxy": "node ../server/archive-proxy.mjs",
    "preview": "npm run build && wrangler dev",
    "fetch:voa": "node scripts/fetch-voa-lessons.mjs",
    "postinstall": "node scripts/copy-ffmpeg-core.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@google/generative-ai": "^0.24.1",
    "@gsap/react": "^2.1.2",
    "@huggingface/transformers": "^3.8.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "gsap": "^3.15.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.16.0",
    "openai": "^6.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/diff": "^7.0.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.6",
    "wrangler": "^4.98.0"
  }
}
